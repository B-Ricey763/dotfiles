#!/usr/bin/env sh

# --- Scripting Addition ---
# Ensure the scripting addition is loaded on startup and after Dock restarts
sudo yabai --load-sa
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"

# --- Scratchpads ---
# 'sticky=on' ensures the scratchpad is always available on your current desktop
# when visible, effectively fixing the "opened on wrong workspace" issue.
yabai -m rule --add app="^Spotify$"         scratchpad=spotify  grid=11:11:1:1:9:9  sticky=on
yabai -m rule --add app="^Messages$"        scratchpad=messages grid=11:6:2:2:2:8   sticky=on
yabai -m rule --add app="^Microsoft Teams$" scratchpad=teams    grid=11:11:1:1:9:9  sticky=on
yabai -m rule --add app="^Slack$"           scratchpad=slack    grid=11:11:1:1:9:9  sticky=on
yabai -m rule --add app="^Discord$"         scratchpad=discord  grid=11:11:1:1:9:9  sticky=on

# --- Window Rules ---
# Keep Ghostty at full opacity and disable its animations for responsiveness
yabai -m rule --add app="^Ghostty$" opacity=1.0

# Exclude specific applications from being tiled/managed by yabai
yabai -m rule --add app="^(LuLu|Calculator|Software Update|Dictionary|VLC|System Preferences|System Settings|zoom.us|Photo Booth|Archive Utility|Python|LibreOffice|App Store|Steam|Activity Monitor)$" manage=off
yabai -m rule --add label="Finder" app="^Finder$" manage=off
yabai -m rule --add label="Safari" app="^Safari$" title="^(General|(Tab|Password|Website|Extension)s|AutoFill|Se(arch|curity)|Privacy|Advance)$" manage=off
yabai -m rule --add label="About This Mac" app="System Information" title="About This Mac" manage=off
yabai -m rule --add app="^FaceTime$" manage=off
yabai -m rule --add label="Select file to save to" app="^Inkscape$" title="Select file to save to" manage=off
yabai -m rule --add app="^Raycast$" manage=off
yabai -m rule --add app="^LastPass$" manage=off

# --- Signals: Focus Management ---

# Logic to find the next window to focus when the current one is gone/minimized.
# 1. Try focusing the window under the mouse.
# 2. Fallback to the first visible window on the current space (excluding scratchpads).
FOCUS_NEXT_WINDOW_ACTION="yabai -m query --windows --window &> /dev/null || \
                          yabai -m window --focus mouse &> /dev/null || \
                          yabai -m window --focus \$(yabai -m query --windows --space | jq -re 'map(select(.\"is-visible\" == true and .scratchpad == \"\")) | .[0].id') &> /dev/null"

# Trigger focus logic when a window is closed
yabai -m signal --add event=window_destroyed active=yes action="$FOCUS_NEXT_WINDOW_ACTION"

# Trigger focus logic when a floating window is minimized
yabai -m signal --add event=window_minimized active=yes action="if \$(yabai -m query --windows --window \$YABAI_WINDOW_ID | jq -r '.\"is-floating\"'); then $FOCUS_NEXT_WINDOW_ACTION; fi"

# --- Signals: App Specific ---

# Ghostty: Force space layout to BSP when Ghostty windows are created or destroyed
yabai -m signal --add app='^Ghostty$' event=window_created   action='yabai -m space --layout bsp'
yabai -m signal --add app='^Ghostty$' event=window_destroyed action='yabai -m space --layout bsp'

# Ghostty: Turn off global animations when Ghostty is focused for extra responsiveness
yabai -m signal --add app='^Ghostty$' event=window_focused action='yabai -m config window_animation_duration 0.0'
# Turn animations back on when focus moves to any other app
yabai -m signal --add app='!^Ghostty$' event=window_focused action='yabai -m config window_animation_duration 0.1'

# --- Signals: Display Changes ---

# Re-apply rules (like padding and tiling) when monitors are added or removed
yabai -m signal --add event=display_added   action="yabai -m rule --apply"
yabai -m signal --add event=display_removed action="yabai -m rule --apply"

# --- Global Config ---
yabai -m config \
                mouse_follows_focus off \
                focus_follows_mouse autofocus \
                window_topmost off \
                window_animation_duration 0.1 \
                window_opacity_duration 0.1 \
                window_opacity on \
                active_window_opacity 1.0 \
                normal_window_opacity 0.95 \
                insert_feedback_color 0xffd75f5f \
                split_ratio 0.50 \
                split_type auto \
                auto_balance on \
                top_padding 12 \
                bottom_padding 12 \
                left_padding 12 \
                right_padding 12 \
                window_gap 12 \
                layout bsp \
                window_shadow float \
                mouse_modifier alt \
                mouse_action1 move \
                mouse_action2 resize \
                mouse_drop_action swap

# Force apply rules to existing windows
yabai -m rule --apply

echo "yabai configuration loaded.."

# --- Borders ---
# Active window gets a purple border (0xFFDC56FE), inactive windows have no border
borders active_color=0xFFDC56FE inactive_color=0x0 width=7.0 &
echo "Borders activated..."
